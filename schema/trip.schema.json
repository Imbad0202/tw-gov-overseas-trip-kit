{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tw-gov-overseas-trip",
  "type": "object",
  "additionalProperties": false,
  "required": ["agency", "traveler", "trip"],
  "properties": {
    "agency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_name"],
      "properties": {
        "full_name": {"type": "string", "minLength": 1, "description": "機關全銜"},
        "unit": {"type": "string", "description": "單位（附件一封面欄）"},
        "short_name": {"type": "string", "description": "機關簡稱"},
        "head_title": {"type": "string", "description": "機關首長職稱（審核表簽章）"}
      }
    },
    "traveler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "title": {"type": "string", "description": "職稱"},
        "rank": {"type": "string", "description": "職等（艙等判定供承辦參考，計算器不自動判）"}
      }
    },
    "trip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose_category", "country", "start_date", "end_date"],
      "properties": {
        "purpose_category": {"type": "string",
          "enum": ["考察", "進修", "研究", "實習", "視察", "訪問", "開會", "談判", "其他"],
          "description": "附件一出國類別"},
        "country": {"type": "string"},
        "city": {"type": "string", "description": "對應日支表城市；未列則用該國『其他』"},
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"},
        "organization": {"type": "string", "description": "境外主辦單位（與 agency 分離）"}
      }
    },
    "summary": {"type": "string", "description": "附件一摘要，renderer 檢查 200-300 中文字"},
    "itinerary": {
      "type": "array",
      "description": "行前手冊（可選）逐日議程／行程表；空或省略則不渲染該區塊",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["items"],
        "properties": {
          "date": {"type": "string", "format": "date", "description": "該日日期（ISO 8601）；可省略，僅以 label 標示時"},
          "label": {"type": "string", "minLength": 1, "description": "該日標題，例如『第一日・抵達』或『行前準備』"},
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["activity"],
              "properties": {
                "time": {"type": "string", "minLength": 1, "description": "時間，彈性表述（『09:00』『上午』『全日』皆可）"},
                "activity": {"type": "string", "minLength": 1, "description": "事項／議程內容"},
                "location": {"type": "string", "minLength": 1, "description": "地點"},
                "note": {"type": "string", "minLength": 1, "description": "備註"}
              }
            }
          }
        }
      }
    },
    "lodging": {
      "type": "array",
      "description": "行前手冊（可選）住宿；多段行程可多筆，空或省略則不渲染",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "description": "住宿名稱"},
          "address": {"type": "string", "minLength": 1, "description": "地址"},
          "phone": {"type": "string", "minLength": 1, "description": "電話"},
          "check_in": {"type": "string", "minLength": 1, "description": "入住日期或時段"},
          "check_out": {"type": "string", "minLength": 1, "description": "退房日期或時段"},
          "note": {"type": "string", "minLength": 1, "description": "備註"}
        }
      }
    },
    "emergency_contacts": {
      "type": "array",
      "description": "行前手冊（可選）緊急聯絡，例如駐外館處、境外主辦、家屬；空或省略則不渲染",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label"],
        "properties": {
          "label": {"type": "string", "minLength": 1, "description": "聯絡類別，例如『駐外館處』『境外主辦』『緊急醫療』"},
          "name": {"type": "string", "minLength": 1, "description": "聯絡人或單位名稱"},
          "phone": {"type": "string", "minLength": 1, "description": "電話"},
          "note": {"type": "string", "minLength": 1, "description": "備註，例如時差、語言、地址"}
        }
      }
    },
    "notes": {
      "type": "array",
      "description": "行前手冊（可選）注意事項清單；空或省略則不渲染",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "flights": {
      "type": "array",
      "description": "航班資訊（可選）。航班查價比較選定後寫入；省略不影響其他文件。多航段用同一 list。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["leg_n", "date", "route", "departure_time", "arrival_time", "flight_no"],
        "properties": {
          "leg_n": {"type": "integer", "minimum": 1, "description": "航段序號"},
          "date": {"type": "string", "format": "date"},
          "route": {"type": "string", "minLength": 1, "description": "e.g. 城市A(AAA)→城市B(BBB)"},
          "departure_time": {"type": "string", "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"},
          "departure_time_next_day": {"type": "boolean", "default": false, "description": "+1 標記。轉機次日才出發 e.g. 08:00+1（對稱 arrival_time_next_day）"},
          "arrival_time": {"type": "string", "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"},
          "arrival_time_next_day": {"type": "boolean", "default": false, "description": "+1 標記。e.g. 21:55→07:25+1"},
          "duration": {"type": "string", "description": "e.g. 5h 20m"},
          "terminal_from": {"type": "string"},
          "terminal_to": {"type": "string"},
          "flight_no": {"type": "string", "minLength": 1, "description": "e.g. ZZ123"},
          "aircraft": {"type": "string", "description": "e.g. Boeing 787-9"},
          "is_layover": {"type": "boolean", "default": false, "description": "標記為轉機段。若 true 通常下一段為轉機後出發。"},
          "layover_hotel": {"type": "string", "description": "轉機過夜住宿（含網址）。is_layover=true 時填。"},
          "source": {"type": "string", "enum": ["searched", "ocr"], "description": "資料來源。searched=航班查價選定寫入；ocr=從素材抽取。缺席視為既有。"}
        }
      }
    }
  }
}
